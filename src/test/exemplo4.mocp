/* Média de um vetor: */
real media(real[], inteiro);
vazio principal(vazio);
real media(real v[], inteiro tamanho) {
inteiro i;
real soma = 0;
para (i = 0; i < tamanho; i = i + 1) {
soma = soma + v[i];
}retornar soma / tamanho;
}
vazio principal(vazio) {
inteiro i, n;
real v[100];
escrevers("Introduza tamanho e valores: ");
n = ler();
para (i = 0; i < n; i = i + 1) { v[i] = ler(); }
escrever(media(v, n));
}
